NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# LMS Decode
# Live / production decode endpoint (used when devmode is absent/false)
LMS_DECODE_URL=http://192.168.1.24/api/lms/v1/decode
# Dev decode endpoint (used when devmode=true)
LMS_DEV_DECODE_URL=http://192.168.1.38/api/lms-dev/v1/decode

# MSSQL Production Database (used by default / when devmode is absent/false)
MS_SQL_DB_SERVER=
MS_SQL_DB_NAME=
MS_SQL_DB_USER=
MS_SQL_DB_PWD=
# MS_SQL_DB_PORT=1433

# MSSQL Dev Database (used when devmode=true)
# These must be configured explicitly. The dev server MUST differ from the
# production server; otherwise devmode writes will land in production.
MS_SQL_DEV_DB_SERVER=
MS_SQL_DEV_DB_NAME=
MS_SQL_DEV_DB_USER=
MS_SQL_DEV_DB_PWD=
# MS_SQL_DEV_DB_PORT=1433

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=devlogger@lapilabs.co.id
DEV_EMAIL_RECIPIENTS=ITnotifLMS@lapilabs.co.id,michael@mikelabs.cloud
