{
  "info": {
    "_postman_id": "devlogger-collection-001",
    "name": "DevLogger API",
    "description": "Complete Postman collection for the DevLogger Node.js backend. Covers health checks, in-memory logs, MSSQL error logs, and the fallback error-report endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns service status, uptime, timestamp and version."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has success shape', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.have.property('status');",
                  "    pm.expect(jsonData.data).to.have.property('uptime');",
                  "    pm.expect(jsonData.data).to.have.property('timestamp');",
                  "    pm.expect(jsonData.data).to.have.property('version');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Logs",
      "item": [
        {
          "name": "List Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logs",
              "host": ["{{baseUrl}}"],
              "path": ["logs"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns array of logs', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"level\": \"error\",\n  \"message\": \"Postman test log\",\n  \"meta\": {\n    \"source\": \"postman\",\n    \"testRun\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/logs",
              "host": ["{{baseUrl}}"],
              "path": ["logs"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Created log has id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.environment.set('logId', jsonData.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Log By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logs/{{logId}}",
              "host": ["{{baseUrl}}"],
              "path": ["logs", "{{logId}}"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns the requested log', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data.id).to.eql(pm.environment.get('logId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Log By ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logs/{{logId}}",
              "host": ["{{baseUrl}}"],
              "path": ["logs", "{{logId}}"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Log - Invalid Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"level\": \"critical\",\n  \"message\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/logs",
              "host": ["{{baseUrl}}"],
              "path": ["logs"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Returns validation error', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "    pm.expect(jsonData.message).to.contain('Validation error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Errors (MSSQL)",
      "item": [
        {
          "name": "List Errors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/errors?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["errors"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns array of errors', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Errors With Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/errors?status_code=500&search=timeout&from=2024-01-01&to=2026-12-31&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["errors"],
              "query": [
                {
                  "key": "status_code",
                  "value": "500"
                },
                {
                  "key": "search",
                  "value": "timeout"
                },
                {
                  "key": "from",
                  "value": "2024-01-01"
                },
                {
                  "key": "to",
                  "value": "2026-12-31"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns filtered results', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Error By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/errors/{{errorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "{{errorId}}"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Send Error Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Investigate this error reported via Postman.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/errors/{{errorId}}/email",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "{{errorId}}", "email"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 when SMTP is configured', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "pm.test('Response contains messageId on success', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(jsonData.success).to.eql(true);",
                  "        pm.expect(jsonData.data).to.have.property('messageId');",
                  "        pm.expect(jsonData.data.recipients).to.be.an('array');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Send Error Email - Custom Recipients",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": [\"michael@mikelabs.cloud\"],\n  \"notes\": \"Sent only to Michael for review.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/errors/{{errorId}}/email",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "{{errorId}}", "email"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 503', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Report (Fallback)",
      "item": [
        {
          "name": "Report Error (save + email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"POST\",\n  \"url\": \"http://localhost:3001/api/some-endpoint\",\n  \"status_code\": 500,\n  \"error_message\": \"Something went wrong in the fallback flow\",\n  \"error_stack\": \"Error: Something went wrong\\n    at handler (src/someEndpoint.js:42:10)\",\n  \"request_body\": {\n    \"field\": \"value\"\n  },\n  \"headers\": {\n    \"content-type\": \"application/json\",\n    \"user-agent\": \"PostmanRuntime/7.36\"\n  },\n  \"userid\": \"POSTMAN_USER\",\n  \"delegatedto\": \"POSTMAN_USER\",\n  \"auth_token\": \"Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\",\n  \"notes\": \"This error was reported through the fallback API.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/errors/report",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "report"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 when SMTP is configured', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "pm.test('Saved to DB and returned id on success', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(jsonData.success).to.eql(true);",
                  "        pm.expect(jsonData.data.saved_to_db).to.eql(true);",
                  "        pm.expect(jsonData.data).to.have.property('id');",
                  "        pm.environment.set('errorId', jsonData.data.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Report Error (email only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"GET\",\n  \"url\": \"http://localhost:3001/api/another-endpoint\",\n  \"status_code\": 422,\n  \"error_message\": \"Validation failed\",\n  \"error_stack\": \"Error: Validation failed\\n    at validate (src/validate.js:15:5)\",\n  \"save_to_db\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/errors/report",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "report"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 503', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "pm.test('Did not save to DB', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(jsonData.data.saved_to_db).to.eql(false);",
                  "        pm.expect(jsonData.data.id).to.be.null;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Report Error - Invalid Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"error_stack\": \"missing url and error_message\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/errors/report",
              "host": ["{{baseUrl}}"],
              "path": ["errors", "report"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Returns validation error', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "    pm.expect(jsonData.message).to.contain('Validation error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Ensure variables exist with sensible defaults",
          "if (!pm.environment.get('baseUrl')) {",
          "    pm.environment.set('baseUrl', 'http://localhost:3000/api/v1');",
          "}",
          "if (!pm.environment.get('errorId')) {",
          "    pm.environment.set('errorId', '6862');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "logId",
      "value": "",
      "type": "string"
    },
    {
      "key": "errorId",
      "value": "6862",
      "type": "string"
    }
  ]
}
