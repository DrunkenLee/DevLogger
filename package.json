{
  "name": "devlogger",
  "version": "1.0.0",
  "description": "Node.js backend boilerplate with Express, Pino, Zod, and Jest (ES modules)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "prepare": "husky"
  },
  "keywords": [
    "nodejs",
    "express",
    "boilerplate",
    "esm",
    "pino",
    "zod",
    "jest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "mssql": "^12.7.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "eslint": "^9.3.0",
    "globals": "^15.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.9.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
